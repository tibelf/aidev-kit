#!/bin/bash
# post-checkout hook: Remind about CLAUDE.md changes
# Installed by ai_project_init

PREV_HEAD=$1
NEW_HEAD=$2
BRANCH_CHECKOUT=$3

# Only run on branch checkout (not file checkout)
if [ "$BRANCH_CHECKOUT" = "1" ]; then
  if [ -f "CLAUDE.md" ]; then
    if ! git diff --quiet "$PREV_HEAD" "$NEW_HEAD" -- CLAUDE.md 2>/dev/null; then
      echo ""
      echo "📝 CLAUDE.md has changed on this branch."
      echo "   Review the changes to ensure Claude Code has accurate context."
      echo ""
    fi
  fi
fi
