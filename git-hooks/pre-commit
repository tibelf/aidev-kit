#!/bin/bash
# pre-commit hook: Block sensitive files and validate CLAUDE.md format
# Installed by ai_project_init

STAGED_FILES=$(git diff --cached --name-only)

# Check for sensitive files
SECRET_PATTERNS=(
  '\.env$'
  '\.env\.'
  'credentials\.json$'
  'auth\.json$'
  '\.pem$'
  '\.key$'
  'secret'
  'token\.json$'
)

blocked=0
for pattern in "${SECRET_PATTERNS[@]}"; do
  matches=$(echo "$STAGED_FILES" | grep -iE "$pattern" || true)
  if [ -n "$matches" ]; then
    echo "⚠ Potentially sensitive file staged:"
    echo "$matches" | while read -r f; do echo "  $f"; done
    blocked=1
  fi
done

if [ "$blocked" -eq 1 ]; then
  echo ""
  echo "Use 'git reset HEAD <file>' to unstage, or 'git commit --no-verify' to bypass."
  exit 1
fi

# Validate CLAUDE.md if modified
if echo "$STAGED_FILES" | grep -q "CLAUDE.md"; then
  if [ -f "CLAUDE.md" ] && ! head -1 CLAUDE.md | grep -q "^#"; then
    echo "⚠ CLAUDE.md should start with a level-1 heading (#)"
    echo "  This is a warning, not blocking the commit."
  fi
fi

exit 0
